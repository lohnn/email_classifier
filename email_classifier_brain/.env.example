# Your email address(es) — comma-separated if you have multiple.
# Used to determine your role (Direct / CC / Hidden).
MY_EMAIL=me@company.com,my.alias@company.com

# IMAP Configuration
# Server to connect to. Defaults to imap.gmail.com if not set.
IMAP_SERVER=imap.gmail.com
# User to authenticate with. If blank, defaults to the first email in MY_EMAIL.
IMAP_USER=me@company.com
# App Password (for Gmail) or standard password
IMAP_PASSWORD=your_app_password_here
# Batch size for fetching emails
IMAP_BATCH_SIZE=50

# Security
# API Key for admin endpoints. If not set, admin access is blocked.
ADMIN_API_KEY=your_secret_admin_key_here

# Background Jobs Toggles (true/false)
# Whether to enable automatic email classification of new emails.
ENABLE_AUTO_CLASSIFICATION=true
# Whether to enable the background job that checks for label corrections from the server.
ENABLE_RECHECK_JOB=true
# Whether to enable periodic re-classification of existing logs.
ENABLE_RECLASSIFY_JOB=true

# Job Intervals (in hours)
# Interval for the recheck job (default: 12)
RECHECK_INTERVAL_HOURS=12
# Interval for the reclassify job (default: same as RECHECK_INTERVAL_HOURS)
# RECLASSIFY_INTERVAL_HOURS=12

# Labels
# Label used to explicitly verify a classification as correct on the server.
VERIFICATION_LABEL=VERIFIED

# ---------------------------------------------------------------------------
# Data & Model Paths
# ---------------------------------------------------------------------------
# Where the trained model lives (default: sibling data repo)
MODEL_DIR=model
# Path to training data directory containing .jsonl files.
TRAINING_DATA_DIR=TrainingData

# ---------------------------------------------------------------------------
# Google Drive Model Sync (rclone)
# ---------------------------------------------------------------------------
# Remote name as configured in `rclone config`
GDRIVE_REMOTE=gdrive
# Folder path within Google Drive for model
GDRIVE_MODEL_PATH=email-classifier-model
# Folder path within Google Drive for storage (database)
GDRIVE_STORAGE_PATH=email-classifier-storage

# Local Storage (Database)
# Directory for storing the database and other persistent data.
STORAGE_DIR=storage
# Direct path to the SQLite database file.
# DB_PATH=storage/email_history.db
